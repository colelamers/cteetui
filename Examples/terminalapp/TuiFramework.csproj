<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <!--
      LangVersion 7.3 is the last version fully compatible with
      netstandard2.0 API surface. This prevents file-scoped namespaces,
      pattern-matching casts, records, init-only setters, and other
      features that do not exist in that target.
    -->
    <LangVersion>7.3</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <RootNamespace>Tui</RootNamespace>
    <AssemblyName>tui-demo</AssemblyName>
  </PropertyGroup>
</Project>
